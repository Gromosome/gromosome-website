rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    //Not now, will be added later
    function isCompanyEmail() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('^[A-Za-z0-9._%+-]+@([A-Za-z0-9-]+\\.)+[A-Za-z]{2,}$')
        && !request.auth.token.email.matches('(?i)^.*@(gmail\\.com|yahoo\\.com|hotmail\\.com|outlook\\.com|live\\.com|icloud\\.com|aol\\.com|proton\\.me|protonmail\\.com|zoho\\.com|yandex\\.com|mail\\.com|gmx\\.com)$');
    }
    function withoutCompanyEmailCheck() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('^[A-Za-z0-9._%+-]+@([A-Za-z0-9-]+\\.)+[A-Za-z]{2,}$');
    }

    match /appointments/{id} {
      allow create: if withoutCompanyEmailCheck()
        && request.resource.data.requestedBy == request.auth.token.email
        && request.resource.data.isCompany == false
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.contactNumber is string
        && request.resource.data.projectType is string
        && request.resource.data.requirement is string;
      allow read, update, delete: if false;
    }

    match /companyAppointments/{id} {
      allow create: if isCompanyEmail()
        && request.resource.data.requestedBy == request.auth.token.email
        && request.resource.data.isCompany == true
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.contactNumber is string
        && request.resource.data.companyName is string
        && request.resource.data.jobTitle is string
        && request.resource.data.projectType is string
        && request.resource.data.requirement is string;
      allow read, update, delete: if false;
    }
  }
}
